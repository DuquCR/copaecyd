# ═══════════════════════════════════════════════
# Copa ECYD Mérida - Variables de Entorno
# ═══════════════════════════════════════════════
# Copia este archivo como .env.local y llena los valores.

# ── Google Sheets API (Service Account) ──
GOOGLE_SERVICE_ACCOUNT_EMAIL=tu-service-account@tu-proyecto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nTU_CLAVE_PRIVADA\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=tu_spreadsheet_id_aqui

# ── Google OAuth (para NextAuth - Login de Admins) ──
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# ── NextAuth ──
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=genera_un_secreto_con_openssl_rand_base64_32

# ── MongoDB Atlas ──
MONGODB_URI=mongodb+srv://usuario:contraseña@cluster.mongodb.net/copa-ecyd

# ── Stripe ──
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Precio de inscripción en centavos MXN ──
INSCRIPTION_PRICE_CENTS=15000

# ── Fecha del torneo (para cuenta regresiva) ──
NEXT_PUBLIC_TOURNAMENT_DATE=2026-06-15T09:00:00
